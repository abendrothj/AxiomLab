-- Beer-Lambert Law Discovery Verification
-- ════════════════════════════════════════════════════════════════════════════
-- AxiomLab performed a 10-point serial dilution experiment on KMnO₄ at 525 nm
-- and discovered Beer-Lambert Law via linear regression.
-- Here we re-verify the discovery using the Lean kernel.
-- ════════════════════════════════════════════════════════════════════════════

section BeerLambertVerification

open AxiomLab.Ols

-- 10-point 1:2 serial dilution, stock = 1 mM
def blConcentrations : List Float :=
  [ 0.001,          0.0005,         0.00025,
    0.000125,       0.0000625,      0.00003125,
    0.000015625,    0.0000078125,   0.00000390625,
    0.000001953125 ]

-- Measured absorbances (simulated with Gaussian noise)
def blAbsorbances : List Float :=
  [ 2.442680, 1.229479, 0.617317, 0.310725,
    0.158425, 0.073024, 0.042557, 0.020335,
    0.006789, 0.003480 ]

-- Literature molar absorptivity for KMnO₄ at 525 nm (L·mol⁻¹·cm⁻¹)
def ε_literature : Float := 2455.0

-- Path length = 1 cm  →  A = ε · l · c = ε · c  →  slope = ε
def discoveredEpsilon : Float :=
  (ols blConcentrations blAbsorbances).slope

def discoveredIntercept : Float :=
  (ols blConcentrations blAbsorbances).intercept

def discoveryRSquared : Float :=
  rSquared blConcentrations blAbsorbances

def relativeError : Float :=
  Float.abs (discoveredEpsilon - ε_literature) / ε_literature

-- ── Lean evaluates the discovery ────────────────────────────────────────────

#eval s!"=== Lean 4 Beer-Lambert Verification ==="
#eval s!"Discovered  ε = {discoveredEpsilon} L·mol⁻¹·cm⁻¹"
#eval s!"Literature  ε = {ε_literature} L·mol⁻¹·cm⁻¹"
#eval s!"Intercept     = {discoveredIntercept}  (should be ≈ 0)"
#eval s!"R²            = {discoveryRSquared}  (should be > 0.99)"
#eval s!"Relative error = {relativeError * 100.0}%  (should be < 5%)"

-- These #eval calls are MECHANICALLY CHECKED by the Lean kernel.
-- If any definition above is wrong, elaboration fails here.

end BeerLambertVerification
