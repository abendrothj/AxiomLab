namespace AxiomLab.Ols

/-- A linear fit: y = slope · x + intercept -/
structure LinearCoeffs where
  slope     : Float
  intercept : Float
  deriving Repr

/-- Predicted value at x under model β -/
def predict (β : LinearCoeffs) (x : Float) : Float :=
  β.slope * x + β.intercept

/-- Residual: observed minus predicted -/
def residual (β : LinearCoeffs) (x y : Float) : Float :=
  y - predict β x

/-- Sum of squared residuals across a dataset -/
def sse (β : LinearCoeffs) (xs ys : List Float) : Float :=
  (List.zipWith (fun x y => let r := residual β x y; r * r) xs ys).foldl (· + ·) 0.0

/-- Sample mean of a list (0 for empty list) -/
def mean (xs : List Float) : Float :=
  xs.foldl (· + ·) 0.0 / (xs.length : Float)

/-- OLS slope estimator: Σ(xᵢ-x̄)(yᵢ-ȳ) / Σ(xᵢ-x̄)²
    This is the Aeneas translation of the nalgebra normal-equation solve. -/
def olsSlope (xs ys : List Float) : Float :=
  let x_bar := mean xs
  let y_bar := mean ys
  let num   := (List.zipWith (fun x y => (x - x_bar) * (y - y_bar)) xs ys).foldl (· + ·) 0.0
  let den   := (xs.map (fun x => let d := x - x_bar; d * d)).foldl (· + ·) 0.0
  if den == 0.0 then 0.0 else num / den

/-- OLS intercept: ȳ − slope · x̄ -/
def olsIntercept (xs ys : List Float) : Float :=
  mean ys - olsSlope xs ys * mean xs

/-- The complete OLS estimator -/
def ols (xs ys : List Float) : LinearCoeffs :=
  { slope     := olsSlope xs ys
    intercept := olsIntercept xs ys }

/-- Coefficient of determination R² = 1 - SS_res / SS_tot -/
def rSquared (xs ys : List Float) : Float :=
  let β     := ols xs ys
  let y_bar := mean ys
  let ss_tot := (ys.map (fun y => let d := y - y_bar; d * d)).foldl (· + ·) 0.0
  let ss_res := sse β xs ys
  if ss_tot == 0.0 then 0.0 else 1.0 - ss_res / ss_tot

end AxiomLab.Ols

