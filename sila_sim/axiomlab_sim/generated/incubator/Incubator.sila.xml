<Feature xmlns="http://www.sila-standard.org" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Category="environment" FeatureVersion="1.0" MaturityLevel="Draft" Originator="org.axiomlab" SiLA2Version="1.0" xsi:schemaLocation="http://www.sila-standard.org https://gitlab.com/SiLA2/sila_base/raw/master/schema/FeatureDefinition.xsd">
  <Identifier>Incubator</Identifier>
  <DisplayName>Incubator</DisplayName>
  <Description>Temperature-controlled incubation chamber for biological samples.</Description>
  <Command>
    <Identifier>SetTemperature</Identifier>
    <DisplayName>Set Temperature</DisplayName>
    <Description>Set the incubator target temperature.</Description>
    <Observable>No</Observable>
    <Parameter>
      <Identifier>TemperatureCelsius</Identifier>
      <DisplayName>Temperature (&#176;C)</DisplayName>
      <Description>Target temperature in Celsius (4&#8211;95&#176;C).</Description>
      <DataType>
        <Basic>Real</Basic>
      </DataType>
    </Parameter>
    <Response>
      <Identifier>ConfirmedTemperature</Identifier>
      <DisplayName>Confirmed Temperature</DisplayName>
      <Description>Confirmed target temperature.</Description>
      <DataType>
        <Basic>Real</Basic>
      </DataType>
    </Response>
  </Command>
  <Command>
    <Identifier>ReadTemperature</Identifier>
    <DisplayName>Read Temperature</DisplayName>
    <Description>Get the current incubator temperature.</Description>
    <Observable>No</Observable>
    <Response>
      <Identifier>CurrentTemperature</Identifier>
      <DisplayName>Current Temperature</DisplayName>
      <Description>Current chamber temperature in Celsius.</Description>
      <DataType>
        <Basic>Real</Basic>
      </DataType>
    </Response>
    <Response>
      <Identifier>TargetTemperature</Identifier>
      <DisplayName>Target Temperature</DisplayName>
      <Description>Current setpoint in Celsius.</Description>
      <DataType>
        <Basic>Real</Basic>
      </DataType>
    </Response>
  </Command>
  <Command>
    <Identifier>Incubate</Identifier>
    <DisplayName>Incubate</DisplayName>
    <Description>Run incubation for a specified duration.</Description>
    <Observable>No</Observable>
    <Parameter>
      <Identifier>DurationMinutes</Identifier>
      <DisplayName>Duration (min)</DisplayName>
      <Description>Incubation time in minutes.</Description>
      <DataType>
        <Basic>Real</Basic>
      </DataType>
    </Parameter>
    <Response>
      <Identifier>ElapsedTime</Identifier>
      <DisplayName>Elapsed Time</DisplayName>
      <Description>Actual elapsed incubation time in minutes.</Description>
      <DataType>
        <Basic>Real</Basic>
      </DataType>
    </Response>
  </Command>
</Feature>
