<Feature xmlns="http://www.sila-standard.org" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Category="liquidhandling" FeatureVersion="1.0" MaturityLevel="Draft" Originator="org.axiomlab" SiLA2Version="1.0" xsi:schemaLocation="http://www.sila-standard.org https://gitlab.com/SiLA2/sila_base/raw/master/schema/FeatureDefinition.xsd">
  <Identifier>LiquidHandler</Identifier>
  <DisplayName>Liquid Handler</DisplayName>
  <Description>Dispense, aspirate and transfer liquids between vessels.</Description>
  <Command>
    <Identifier>Dispense</Identifier>
    <DisplayName>Dispense</DisplayName>
    <Description>Dispense a volume of liquid into a target vessel.</Description>
    <Observable>No</Observable>
    <Parameter>
      <Identifier>TargetVessel</Identifier>
      <DisplayName>Target Vessel</DisplayName>
      <Description>ID of the vessel to dispense into.</Description>
      <DataType>
        <Basic>String</Basic>
      </DataType>
    </Parameter>
    <Parameter>
      <Identifier>VolumeUl</Identifier>
      <DisplayName>Volume (&#181;L)</DisplayName>
      <Description>Volume to dispense in microlitres.</Description>
      <DataType>
        <Basic>Real</Basic>
      </DataType>
    </Parameter>
    <Response>
      <Identifier>DispensedVolumeUl</Identifier>
      <DisplayName>Dispensed Volume (&#181;L)</DisplayName>
      <Description>Actual volume dispensed, confirmed by hardware.</Description>
      <DataType>
        <Basic>Real</Basic>
      </DataType>
    </Response>
  </Command>
  <Command>
    <Identifier>Aspirate</Identifier>
    <DisplayName>Aspirate</DisplayName>
    <Description>Aspirate a volume of liquid from a source vessel.</Description>
    <Observable>No</Observable>
    <Parameter>
      <Identifier>SourceVessel</Identifier>
      <DisplayName>Source Vessel</DisplayName>
      <Description>ID of the vessel to aspirate from.</Description>
      <DataType>
        <Basic>String</Basic>
      </DataType>
    </Parameter>
    <Parameter>
      <Identifier>VolumeUl</Identifier>
      <DisplayName>Volume (&#181;L)</DisplayName>
      <Description>Volume to aspirate in microlitres.</Description>
      <DataType>
        <Basic>Real</Basic>
      </DataType>
    </Parameter>
    <Response>
      <Identifier>AspiratedVolumeUl</Identifier>
      <DisplayName>Aspirated Volume (&#181;L)</DisplayName>
      <Description>Actual volume aspirated, confirmed by hardware.</Description>
      <DataType>
        <Basic>Real</Basic>
      </DataType>
    </Response>
  </Command>
</Feature>
